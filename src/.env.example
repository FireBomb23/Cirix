# Copia este ficheiro para .env e preenche com os teus dados.
# Liga-se a MESMA base de dados PostgreSQL usada pelo projeto Django (BD/).
DB_NAME=projeto_BD
DB_USER=postgres
DB_PASSWORD=a_tua_password
DB_HOST=localhost
DB_PORT=5432

PORT=3000

# Chave secreta para assinar os tokens JWT (autenticacao). Usa um valor longo e aleatorio.
JWT_SECRET=troca-esta-chave-por-uma-aleatoria-bem-grande
JWT_EXPIRES_IN=2h

# Deploy/cloud (opcional). Em local deixa em branco.
# DB_SSL=true                       # ativa SSL (ex.: Neon/Render)
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require   # alternativa aos DB_* acima
